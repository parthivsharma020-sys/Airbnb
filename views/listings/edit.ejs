<%-layout("/layouts/boilerPlate")%>
  <body>
    <h2>Edit the information</h2>
    <form action="/listings/<%=listing._id%>?_method=PUT" method="POST">
      <input
        type="text"
        name="listing[title]"
        id=""
        value="<%=listing.title%>"
        placeholder="Enter title"
      />
      <br />
      <br />
      <textarea type="text" name="listing[description]" id="" value="">
<%=listing.description %></textarea
      >
      <br />
      <br />
      <input type="text" name="listing[image]" id="" value="<%=listing.img%>" />
      <br />
      <br />
      <input
        type="number"
        name="listing[price]"
        id=""
        value="<%=listing.price%>"
      />
      <br />
      <br />
      <input
        type="text"
        name="listing[country]"
        id=""
        value="<%=listing.country%>"
      />
      <br /><br />
      <input
        type="text"
        name="listing[location]"
        id=""
        value="<%=listing.location%>"
      />

      <button>submit</button>
    </form>
  </body>

